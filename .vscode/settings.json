  "editor.tokenColorCustomizations": {
    "comments": {
      "foreground": "#8C78B0",
      "fontStyle": "italic"
    },
    "strings": "#FFD36E",
    "keywords": "#7CFF6B",
    "functions": "#62D9FF",
    "numbers": "#FF37B7",
    "variables": "#F4EFFF",
    "types": "#62D9FF",
    "textMateRules": [
      {
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#8C78B0",
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "string",
          "constant.other.symbol"
        ],
        "settings": {
          "foreground": "#FFD36E"
        }
      },
      {
        "scope": [
          "keyword",
          "storage",
          "storage.type",
          "storage.modifier"
        ],
        "settings": {
          "foreground": "#7CFF6B"
        }
      },
      {
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call",
          "variable.function"
        ],
        "settings": {
          "foreground": "#62D9FF"
        }
      },
      {
        "scope": [
          "entity.name.type",
          "entity.name.class",
          "entity.name.struct",
          "entity.name.interface",
          "support.type",
          "support.class"
        ],
        "settings": {
          "foreground": "#62D9FF"
        }
      },
      {
        "scope": [
          "constant.numeric",
          "keyword.operator",
          "storage.type.operator",
          "punctuation.separator",
          "punctuation.accessor"
        ],
        "settings": {
          "foreground": "#FF37B7"
        }
      },
      {
        "scope": [
          "variable",
          "variable.other",
          "variable.parameter",
          "meta.object-literal.key",
          "support.variable"
        ],
        "settings": {
          "foreground": "#F4EFFF"
        }
      }
    ]
  }
}
